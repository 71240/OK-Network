<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>OK Safe Parking Network • Complete Map</title>
    <link rel="icon" href="logo.png" type="image/png">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        * { box-sizing: border-box; font-family: system-ui, sans-serif; }
        body { margin: 0; padding: 20px; background: #1a2a1f; display: flex; justify-content: center; }
        .container { max-width: 1400px; width: 100%; background: #f5f3e8; border-radius: 32px; overflow: hidden; }
        .header { background: #2c5e2e; color: white; padding: 16px 24px; display: flex; justify-content: space-between; flex-wrap: wrap; align-items: center; gap: 12px; }
        .logo-area { display: flex; align-items: center; gap: 12px; }
        h1 { margin: 0; font-size: 1.6rem; }
        .sub { font-style: italic; opacity: 0.9; font-size: 0.85rem; }
        .user-area { background: #1f3b20; padding: 8px 16px; border-radius: 60px; display: flex; gap: 12px; align-items: baseline; flex-wrap: wrap; }
        .username-display { background: #e9b35f; color: #1e2a1a; padding: 5px 12px; border-radius: 40px; font-weight: bold; }
        .change-name-btn, .admin-btn { background: #f5bc70; border: none; padding: 5px 12px; border-radius: 30px; cursor: pointer; font-weight: bold; }
        .admin-btn { background: #ffaa44; margin-left: 8px; }
        .map-container { height: 550px; width: 100%; }
        #map { height: 100%; width: 100%; background: #c8e0d0; }
        .location-panel { padding: 20px; background: #fffdf7; max-height: 500px; overflow-y: auto; }
        .location-title { font-size: 1.4rem; font-weight: bold; display: flex; gap: 12px; flex-wrap: wrap; border-bottom: 2px solid #ddd; padding-bottom: 10px; align-items: center; }
        .vote-buttons { display: flex; gap: 20px; margin: 15px 0; }
        .thumbs { background: #eee; border: none; padding: 10px 20px; border-radius: 60px; cursor: pointer; display: flex; align-items: center; gap: 8px; font-weight: bold; }
        .thumbs-up { background: #c8e6d9; }
        .thumbs-down { background: #ffe0e0; }
        .score { font-size: 1rem; background: #2c5e2e20; padding: 5px 12px; border-radius: 40px; }
        .comments-section { margin-top: 20px; padding: 15px; background: #f9f6ed; border-radius: 24px; }
        .comment-list { max-height: 250px; overflow-y: auto; margin-bottom: 15px; background: white; padding: 10px; border-radius: 20px; }
        .comment-item { border-bottom: 1px solid #ddd; padding: 10px; }
        .comment-header { display: flex; justify-content: space-between; flex-wrap: wrap; margin-bottom: 5px; }
        .comment-name { font-weight: bold; color: #2c5e2e; }
        .comment-time { font-size: 0.7rem; color: gray; }
        .add-comment { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 15px; }
        .add-comment input { flex: 3; padding: 10px; border-radius: 40px; border: 1px solid #ccc; }
        .add-comment button { background: #2c5e2e; color: white; border: none; padding: 8px 20px; border-radius: 40px; cursor: pointer; }
        .user-spot-section { margin-top: 20px; padding: 15px; background: #e8f0fe; border-radius: 24px; border: 2px dashed #2c5e2e; }
        .user-spot-form { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
        .user-spot-form input { padding: 8px; border-radius: 20px; border: 1px solid #ccc; flex: 1; min-width: 150px; }
        .user-spot-form button { background: #2c5e2e; color: white; border: none; padding: 8px 16px; border-radius: 40px; cursor: pointer; }
        .admin-panel { background: #fff1d6; margin-top: 15px; border-radius: 24px; padding: 12px; border: 1px solid #e0b354; }
        .pending-item { background: white; padding: 8px 12px; margin: 8px 0; border-radius: 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; font-size: 0.8rem; }
        .approve-btn { background: #2c5e2e; color: white; border: none; padding: 5px 12px; border-radius: 30px; cursor: pointer; }
        .reject-btn { background: #9e2d2d; color: white; border: none; padding: 5px 12px; border-radius: 30px; cursor: pointer; }
        .export-btn { background: #4a6fa5; color: white; border: none; padding: 8px 16px; border-radius: 30px; margin: 10px 20px 20px auto; display: block; cursor: pointer; }
        .warning { background: #fff1c1; padding: 8px; border-radius: 20px; margin: 10px 20px; text-align: center; font-size: 0.8rem; }
        footer { font-size: 0.7rem; text-align: center; padding: 15px; color: #4a4a3a; }
        .sync-indicator { position: fixed; bottom: 20px; right: 20px; background: #2c5e2e; color: white; padding: 5px 12px; border-radius: 20px; font-size: 0.7rem; z-index: 1000; }
        .stats-bar { background: #2c5e2e20; padding: 8px 20px; display: flex; gap: 20px; font-size: 0.75rem; justify-content: space-between; flex-wrap: wrap; }
        .category-filter { padding: 10px 20px; background: white; border-bottom: 1px solid #ddd; display: flex; gap: 6px; flex-wrap: wrap; max-height: 120px; overflow-y: auto; }
        .filter-btn { background: #e0e0e0; border: none; padding: 4px 10px; border-radius: 20px; cursor: pointer; font-size: 0.7rem; }
        .filter-btn.active { background: #2c5e2e; color: white; }
        @media (max-width: 700px) { .location-title { font-size: 1.1rem; } }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="logo-area">
            <div><h1>🌙 OK Safe Parking Network</h1><div class="sub">Complete map • 200+ locations • Community-rated</div></div>
        </div>
        <div class="user-area">
            <span>👤</span>
            <span id="usernameSpan" class="username-display">loading...</span>
            <button id="changeNameBtn" class="change-name-btn">Change name</button>
            <button id="adminToggleBtn" class="admin-btn">🔐 Admin</button>
        </div>
    </div>
    <div class="stats-bar" id="statsBar">Loading locations...</div>
    <div class="category-filter" id="categoryFilter"></div>
    <div class="map-container"><div id="map"></div></div>
    <div class="location-panel">
        <div class="location-title"><span id="selectedPlaceName">Select a marker</span><span id="voteScore" class="score"></span></div>
        <div class="vote-buttons">
            <button id="thumbUpBtn" class="thumbs thumbs-up">👍 Safe overnight</button>
            <button id="thumbDownBtn" class="thumbs thumbs-down">👎 Not safe / risky</button>
        </div>
        <div class="comments-section">
            <strong>💬 Community Reports</strong>
            <div id="commentList" class="comment-list">Loading...</div>
            <div class="add-comment">
                <input type="text" id="commentInput" placeholder="Share your experience..." maxlength="200">
                <button id="postCommentBtn">Post</button>
            </div>
        </div>
        <div class="user-spot-section">
            <strong>📍 Missed a spot? Add it</strong>
            <div class="user-spot-form">
                <input type="text" id="newSpotName" placeholder="Business name">
                <input type="text" id="newSpotDesc" placeholder="Address / notes">
                <button id="addSpotBtn">➕ Suggest (needs approval)</button>
            </div>
            <small>Click on map where the spot is located first</small>
        </div>
        <div id="adminPanel" class="admin-panel" style="display:none;">
            <strong>🛠 Admin: Pending spots</strong>
            <div id="pendingList">No pending submissions.</div>
        </div>
    </div>
    <button id="exportCsvBtn" class="export-btn">📎 Download CSV Report</button>
    <div class="warning">⚠️ Always check local signs. These are potential overnight parking spots - policies change. Be respectful and safe.</div>
    <footer>Anonymous • Names saved locally • All data shared across users • Community-rated</footer>
</div>
<div id="syncStatus" class="sync-indicator">🟢 Live</div>

<!-- Location Data Files -->
<script src="locations/walmarts.js"></script>
<script src="locations/crackerbarrel.js"></script>
<script src="locations/loves.js"></script>
<script src="locations/pilot.js"></script>
<script src="locations/casinos.js"></script>
<script src="locations/hospitals.js"></script>
<script src="locations/gyms.js"></script>
<script src="locations/restareas.js"></script>

<script>
    const JSONBIN_BIN_ID = "69e921d136566621a8df20c8";
    const JSONBIN_API_KEY = "$2a$10$pc9P7XGCOIL7n0.XPQs94eFWfy8LyNKP2d8flF55jf6Tkrli4hUXW";
    
    let isAdminMode = false;
    let currentUsername = "";
    let currentPlaceId = null;
    let map, markers = [];
    let allLocations = [];
    let filteredLocations = [];
    let currentFilter = "all";
    let pendingSpotLatLng = null;
    let syncInProgress = false;
    
    // Combine all locations from separate files
    function combineAllLocations() {
        let combined = [];
        
        if (typeof walmartLocations !== 'undefined') combined.push(...walmartLocations);
        if (typeof crackerBarrelLocations !== 'undefined') combined.push(...crackerBarrelLocations);
        if (typeof lovesLocations !== 'undefined') combined.push(...lovesLocations);
        if (typeof pilotLocations !== 'undefined') combined.push(...pilotLocations);
        if (typeof casinoLocations !== 'undefined') combined.push(...casinoLocations);
        if (typeof hospitalLocations !== 'undefined') combined.push(...hospitalLocations);
        if (typeof gymLocations !== 'undefined') combined.push(...gymLocations);
        if (typeof restAreaLocations !== 'undefined') combined.push(...restAreaLocations);
        
        // Add unique IDs
        return combined.map((loc, idx) => ({ ...loc, id: `${loc.category.toLowerCase().replace(/ /g, '_')}_${idx}`, isUserSpot: false }));
    }
    
    let remoteData = { votes: {}, comments: {}, approvedSpots: [], pendingSpots: [] };
    
    async function loadFromJSONBin() {
        try {
            const response = await fetch(`https://api.jsonbin.io/v3/b/${JSONBIN_BIN_ID}/latest`, {
                headers: { "X-Master-Key": JSONBIN_API_KEY }
            });
            if (response.ok) {
                const data = await response.json();
                if (data.record) {
                    remoteData = data.record;
                    if (!remoteData.votes) remoteData.votes = {};
                    if (!remoteData.comments) remoteData.comments = {};
                    if (!remoteData.approvedSpots) remoteData.approvedSpots = [];
                    if (!remoteData.pendingSpots) remoteData.pendingSpots = [];
                }
            }
        } catch (err) { console.error("JSONbin error:", err); }
    }
    
    async function saveToJSONBin() {
        if (syncInProgress) return;
        syncInProgress = true;
        try {
            await fetch(`https://api.jsonbin.io/v3/b/${JSONBIN_BIN_ID}`, {
                method: "PUT",
                headers: { "Content-Type": "application/json", "X-Master-Key": JSONBIN_API_KEY },
                body: JSON.stringify(remoteData)
            });
        } catch (err) { console.error("Save error:", err); }
        finally { syncInProgress = false; }
    }
    
    function getApprovedSpotsCombined() {
        const approvedUser = (remoteData.approvedSpots || []).map(s => ({
            id: s.id, name: s.name, lat: s.lat, lng: s.lng,
            category: s.description || "Community spot", isUserSpot: true,
            submittedBy: s.submittedBy, city: s.city || "User added"
        }));
        return [...allLocations, ...approvedUser];
    }
    
    function getColor(yes, no) {
        if (yes > 0 && no === 0) return "#2e7d32";
        if (no > 0 && yes === 0) return "#c62828";
        if (yes > 0 && no > 0) return "#f9a825";
        return "#ffd966";
    }
    
    function createMarkerIcon(color, isUserSpot = false) {
        if (isUserSpot) {
            return L.divIcon({ html: `<div style="background:#2c5e2e; width:22px; height:22px; border-radius:50%; border:2px solid white; text-align:center; line-height:22px; font-size:12px;">📍</div>`, iconSize: [22, 22], popupAnchor: [0, -11] });
        }
        return L.divIcon({ html: `<div style="background-color:${color}; width:16px; height:16px; border-radius:50%; border:2px solid white; box-shadow:0 1px 3px black;"></div>`, iconSize: [16, 16], popupAnchor: [0, -8] });
    }
    
    function applyFilter() {
        let locationsToShow = getApprovedSpotsCombined();
        if (currentFilter === "all") filteredLocations = locationsToShow;
        else filteredLocations = locationsToShow.filter(l => l.category === currentFilter);
        document.getElementById("statsBar").innerHTML = `📍 ${filteredLocations.length} locations shown • ${locationsToShow.length} total • 💬 ${Object.keys(remoteData.comments).reduce((a,b)=>a+(remoteData.comments[b]?.length||0),0)} reports`;
        rebuildMarkers();
    }
    
    function rebuildMarkers() {
        if (!map) return;
        markers.forEach(m => map.removeLayer(m));
        markers = [];
        for (let loc of filteredLocations) {
            const votes = remoteData.votes[loc.id] || { yes: 0, no: 0 };
            const color = getColor(votes.yes, votes.no);
            const icon = createMarkerIcon(color, loc.isUserSpot);
            const marker = L.marker([loc.lat, loc.lng], { icon }).addTo(map);
            marker.id = loc.id;
            let popupHtml = `<b>${escapeHtml(loc.name)}</b><br>📌 ${loc.city}<br>✅ ${votes.yes} 👍 | 👎 ${votes.no}`;
            if (loc.isUserSpot) popupHtml += `<br><small>Community added</small>`;
            popupHtml += `<br><button onclick="window.selectLocation('${loc.id}')">Details & Report</button>`;
            marker.bindPopup(popupHtml);
            marker.on('click', () => selectLocation(loc.id));
            markers.push(marker);
        }
        if (currentPlaceId && filteredLocations.find(l => l.id === currentPlaceId)) selectLocation(currentPlaceId);
        else if (filteredLocations.length) selectLocation(filteredLocations[0].id);
    }
    
    function rebuildFullMapAndUI() {
        applyFilter();
        renderAdminPanel();
        // Build filter buttons dynamically
        const allSpots = getApprovedSpotsCombined();
        const categories = [...new Set(allSpots.map(l => l.category))];
        const filterDiv = document.getElementById("categoryFilter");
        filterDiv.innerHTML = `<button class="filter-btn active" data-cat="all">All (${allSpots.length})</button>` + categories.map(c => `<button class="filter-btn" data-cat="${c}">${c} (${allSpots.filter(l=>l.category===c).length})</button>`).join("");
        document.querySelectorAll(".filter-btn").forEach(btn => { btn.onclick = () => { document.querySelectorAll(".filter-btn").forEach(b => b.classList.remove("active")); btn.classList.add("active"); currentFilter = btn.getAttribute("data-cat"); applyFilter(); }; });
    }
    
    function selectLocation(placeId) {
        currentPlaceId = placeId;
        const allSpots = getApprovedSpotsCombined();
        const loc = allSpots.find(l => l.id === placeId);
        if (loc) document.getElementById("selectedPlaceName").innerHTML = `${escapeHtml(loc.name)} <span style="font-size:0.8rem;">📍 ${loc.city}</span>`;
        const votes = remoteData.votes[placeId] || { yes: 0, no: 0 };
        let status = votes.yes > votes.no ? "🟢 Mostly safe" : votes.no > votes.yes ? "🔴 Reported risky" : "⚪ No reports yet";
        document.getElementById("voteScore").innerHTML = `👍 ${votes.yes} | 👎 ${votes.no} — ${status}`;
        const comments = remoteData.comments[placeId] || [];
        const commentDiv = document.getElementById("commentList");
        if (comments.length === 0) commentDiv.innerHTML = "<em>No reports yet. Share your experience!</em>";
        else commentDiv.innerHTML = comments.slice().reverse().map(c => `<div class="comment-item"><div class="comment-header"><span class="comment-name">${escapeHtml(c.username)}</span><span class="comment-time">${escapeHtml(c.timestamp)}</span></div><div>${escapeHtml(c.text)}</div></div>`).join("");
    }
    
    async function vote(type) {
        if (!currentPlaceId) { alert("Click a marker first"); return; }
        if (!remoteData.votes[currentPlaceId]) remoteData.votes[currentPlaceId] = { yes: 0, no: 0 };
        if (type === 'yes') remoteData.votes[currentPlaceId].yes++;
        else remoteData.votes[currentPlaceId].no++;
        await saveToJSONBin();
        selectLocation(currentPlaceId);
        rebuildFullMapAndUI();
    }
    
    async function addComment() {
        const text = document.getElementById("commentInput").value;
        if (!currentPlaceId) { alert("Select a location first"); return; }
        if (!text.trim()) return;
        if (!remoteData.comments[currentPlaceId]) remoteData.comments[currentPlaceId] = [];
        remoteData.comments[currentPlaceId].push({ username: currentUsername, text: text.substring(0, 200), timestamp: new Date().toLocaleString() });
        await saveToJSONBin();
        selectLocation(currentPlaceId);
        document.getElementById("commentInput").value = "";
    }
    
    async function suggestUserSpot() {
        if (!pendingSpotLatLng) { alert("Click on the map where this spot is located first"); return; }
        const name = document.getElementById("newSpotName").value.trim();
        if (!name) { alert("Enter a business or location name"); return; }
        const desc = document.getElementById("newSpotDesc").value.trim();
        remoteData.pendingSpots.push({ id: "pending_" + Date.now(), name: name, description: desc || "Community suggestion", lat: pendingSpotLatLng.lat, lng: pendingSpotLatLng.lng, submittedBy: currentUsername, submittedAt: new Date().toLocaleString() });
        await saveToJSONBin();
        alert("Spot suggested! Admin will review.");
        document.getElementById("newSpotName").value = "";
        document.getElementById("newSpotDesc").value = "";
        pendingSpotLatLng = null;
        if (isAdminMode) renderAdminPanel();
    }
    
    async function approveSpot(idx) { let pending = remoteData.pendingSpots[idx]; remoteData.approvedSpots.push({ id: "user_" + Date.now(), name: pending.name, description: pending.description, lat: pending.lat, lng: pending.lng, submittedBy: pending.submittedBy, submittedAt: pending.submittedAt, city: "Community", category: "Community Spot" }); remoteData.pendingSpots.splice(idx, 1); await saveToJSONBin(); rebuildFullMapAndUI(); alert("Approved!"); }
    async function rejectSpot(idx) { if (confirm("Reject?")) { remoteData.pendingSpots.splice(idx, 1); await saveToJSONBin(); renderAdminPanel(); } }
    
    function renderAdminPanel() {
        let container = document.getElementById("pendingList");
        if (!container) return;
        let pendings = remoteData.pendingSpots || [];
        if (pendings.length === 0) { container.innerHTML = "<em>No pending submissions.</em>"; return; }
        container.innerHTML = "";
        pendings.forEach((p, idx) => { let div = document.createElement("div"); div.className = "pending-item"; div.innerHTML = `<div><b>${escapeHtml(p.name)}</b><br><small>📍 ${p.lat.toFixed(4)}, ${p.lng.toFixed(4)}<br>📝 ${escapeHtml(p.description)}<br>👤 ${escapeHtml(p.submittedBy)}</small></div><div><button class="approve-btn" data-idx="${idx}">✅ Approve</button> <button class="reject-btn" data-idx="${idx}">❌ Reject</button></div>`; container.appendChild(div); });
        document.querySelectorAll(".approve-btn").forEach(btn => btn.addEventListener("click", () => approveSpot(parseInt(btn.getAttribute("data-idx")))));
        document.querySelectorAll(".reject-btn").forEach(btn => btn.addEventListener("click", () => rejectSpot(parseInt(btn.getAttribute("data-idx")))));
    }
    
    function exportCSV() {
        let rows = [["ID", "Name", "City", "Category", "Yes Votes", "No Votes"]];
        let allSpots = getApprovedSpotsCombined();
        for (let loc of allSpots) { let votes = remoteData.votes[loc.id] || { yes: 0, no: 0 }; rows.push([loc.id, loc.name, loc.city || "", loc.category, votes.yes, votes.no]); }
        let csv = rows.map(r => r.map(c => `"${String(c).replace(/"/g, '""')}"`).join(",")).join("\n");
        let link = document.createElement("a"); link.href = URL.createObjectURL(new Blob([csv], { type: "text/csv" })); link.download = `ok_parking_${new Date().toISOString().slice(0,10)}.csv`; link.click();
    }
    
    function escapeHtml(str) { if (!str) return ""; return String(str).replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m])); }
    
    const adjectives = ["Quiet", "Sleepy", "Nocturnal", "Stealth", "Gray", "Gentle", "Wandering", "Calm", "Deep", "Lone", "Silver", "Cozy", "Friendly", "Brave", "Clever", "Mellow"];
    const nouns = ["Owl", "Caravan", "Camper", "Tumbleweed", "PrairieDog", "Roadrunner", "Coyote", "Moon", "Shadow", "Wanderer", "Hatchback", "Prius", "Van", "Ranger", "Nomad"];
    function generateUsername() { return adjectives[Math.floor(Math.random() * adjectives.length)] + nouns[Math.floor(Math.random() * nouns.length)]; }
    function loadUsername() { let stored = localStorage.getItem("ok_username"); if (stored) currentUsername = stored; else { currentUsername = generateUsername(); localStorage.setItem("ok_username", currentUsername); } document.getElementById("usernameSpan").innerText = currentUsername; }
    function changeUsername() { let newName = prompt("New username (or blank for random):"); if (newName && newName.trim()) currentUsername = newName.trim().substring(0, 25); else currentUsername = generateUsername(); localStorage.setItem("ok_username", currentUsername); document.getElementById("usernameSpan").innerText = currentUsername; }
    
    async function init() {
        allLocations = combineAllLocations();
        await loadFromJSONBin();
        loadUsername();
        map = L.map('map').setView([35.5, -97.2], 7.2);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { attribution: '© OpenStreetMap & CartoDB', subdomains: 'abcd', maxZoom: 19 }).addTo(map);
        map.on('click', (e) => { pendingSpotLatLng = e.latlng; L.popup().setLatLng(e.latlng).setContent("📍 Location set! Enter name and click 'Suggest spot'").openOn(map); });
        rebuildFullMapAndUI();
        document.getElementById("thumbUpBtn").onclick = () => vote('yes');
        document.getElementById("thumbDownBtn").onclick = () => vote('no');
        document.getElementById("postCommentBtn").onclick = addComment;
        document.getElementById("changeNameBtn").onclick = changeUsername;
        document.getElementById("addSpotBtn").onclick = suggestUserSpot;
        document.getElementById("exportCsvBtn").onclick = exportCSV;
        document.getElementById("adminToggleBtn").onclick = () => { let pwd = prompt("Enter admin password:"); if (pwd === "okcadmin2025") { isAdminMode = true; document.getElementById("adminPanel").style.display = "block"; renderAdminPanel(); alert("Admin mode - approve/reject spots"); } else alert("Wrong password"); };
    }
    
    window.selectLocation = selectLocation;
    init();
</script>
</body>
</html>
