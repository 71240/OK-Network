<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>OK Safe Parking Network</title>
    <link rel="icon" href="logo.png" type="image/png">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-database-compat.js"></script>
    <style>
        * {
            box-sizing: border-box;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        }
        body {
            margin: 0;
            padding: 20px;
            background: #1a2a1f;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .container {
            max-width: 1400px;
            width: 100%;
            background: #f5f3e8;
            border-radius: 32px;
            box-shadow: 0 20px 35px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        .header {
            background: #2c5e2e;
            color: white;
            padding: 16px 24px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }
        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .logo-img {
            height: 45px;
            width: auto;
        }
        h1 {
            margin: 0;
            font-size: 1.6rem;
        }
        .sub {
            font-style: italic;
            opacity: 0.9;
            font-size: 0.85rem;
        }
        .user-area {
            background: #1f3b20;
            padding: 8px 16px;
            border-radius: 60px;
            display: flex;
            gap: 12px;
            align-items: baseline;
            flex-wrap: wrap;
        }
        .username-display {
            font-weight: bold;
            background: #e9b35f;
            color: #1e2a1a;
            padding: 5px 12px;
            border-radius: 40px;
            font-size: 0.9rem;
        }
        .change-name-btn {
            background: #f5bc70;
            border: none;
            padding: 5px 12px;
            border-radius: 30px;
            cursor: pointer;
            font-weight: bold;
        }
        .map-container {
            height: 450px;
            width: 100%;
            border-bottom: 4px solid #c0a76b;
        }
        #map {
            height: 100%;
            width: 100%;
            background: #c8e0d0;
        }
        .location-panel {
            padding: 20px;
            background: #fffdf7;
        }
        .location-title {
            font-size: 1.8rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            border-bottom: 2px solid #ddd;
            padding-bottom: 10px;
        }
        .vote-buttons {
            display: flex;
            gap: 20px;
            margin: 15px 0;
        }
        .thumbs {
            background: #eee;
            border: none;
            padding: 10px 20px;
            border-radius: 60px;
            cursor: pointer;
            transition: 0.1s;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 1.2rem;
            font-weight: bold;
        }
        .thumbs img {
            width: 32px;
            height: 32px;
        }
        .thumbs-up {
            background: #c8e6d9;
            color: #1b5e2a;
        }
        .thumbs-down {
            background: #ffe0e0;
            color: #9a2e2e;
        }
        .score {
            font-size: 1.3rem;
            margin-left: 10px;
            background: #2c5e2e20;
            padding: 5px 12px;
            border-radius: 40px;
        }
        .comments-section {
            margin-top: 20px;
            background: #f9f6ed;
            padding: 15px;
            border-radius: 24px;
        }
        .comment-list {
            max-height: 300px;
            overflow-y: auto;
            margin-bottom: 15px;
            background: white;
            padding: 10px;
            border-radius: 20px;
        }
        .comment-item {
            border-bottom: 1px solid #ddd;
            padding: 10px;
        }
        .comment-header {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            margin-bottom: 5px;
        }
        .comment-name {
            font-weight: bold;
            color: #2c5e2e;
        }
        .comment-time {
            font-size: 0.7rem;
            color: gray;
        }
        .old-comment-warning {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 5px 8px;
            margin-top: 5px;
            font-size: 0.75rem;
        }
        .add-comment {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 15px;
        }
        .add-comment input {
            flex: 3;
            padding: 10px;
            border-radius: 40px;
            border: 1px solid #ccc;
        }
        .add-comment button {
            background: #2c5e2e;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 40px;
            cursor: pointer;
        }
        .user-spot-section {
            margin-top: 20px;
            padding: 15px;
            background: #e8f0fe;
            border-radius: 24px;
            border: 2px dashed #2c5e2e;
        }
        .user-spot-form {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
        }
        .user-spot-form input {
            padding: 8px;
            border-radius: 20px;
            border: 1px solid #ccc;
            flex: 1;
            min-width: 150px;
        }
        .user-spot-form button {
            background: #2c5e2e;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 40px;
            cursor: pointer;
        }
        .export-btn {
            background: #4a6fa5;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 30px;
            margin: 10px 20px 20px auto;
            display: block;
            cursor: pointer;
        }
        .warning {
            background: #fff1c1;
            padding: 8px;
            border-radius: 20px;
            margin: 10px 20px;
            text-align: center;
            font-size: 0.8rem;
        }
        footer {
            font-size: 0.7rem;
            text-align: center;
            padding: 15px;
            color: #4a4a3a;
        }
        @media (max-width: 700px) {
            .location-title { font-size: 1.3rem; }
            .thumbs { padding: 5px 12px; }
            .thumbs img { width: 24px; height: 24px; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="logo-area">
            <img src="logo.png" alt="Logo" class="logo-img" onerror="this.style.display='none'">
            <div>
                <h1>🌙 OK Safe Parking Network</h1>
                <div class="sub">Live community votes • everyone sees updates</div>
            </div>
        </div>
        <div class="user-area">
            <span>👤 You are:</span>
            <span id="usernameSpan" class="username-display">loading...</span>
            <button id="changeNameBtn" class="change-name-btn">🎭 Change name</button>
        </div>
    </div>
    <div class="map-container">
        <div id="map"></div>
    </div>
    <div class="location-panel">
        <div class="location-title">
            <span id="selectedPlaceName">Select a marker</span>
            <span id="voteScore" class="score"></span>
        </div>
        <div class="vote-buttons">
            <button id="thumbUpBtn" class="thumbs thumbs-up"><img src="ThumbsUp.png" alt="👍" onerror="this.src='https://cdn-icons-png.flaticon.com/512/190/190411.png'"> Yes (safe)</button>
            <button id="thumbDownBtn" class="thumbs thumbs-down"><img src="ThumbsDown.png" alt="👎" onerror="this.src='https://cdn-icons-png.flaticon.com/512/190/190417.png'"> No (risky)</button>
        </div>
        
        <div class="comments-section">
            <strong>💬 Community comments</strong>
            <div id="commentList" class="comment-list">Loading comments...</div>
            <div class="add-comment">
                <input type="text" id="commentInput" placeholder="Share your overnight experience..." maxlength="200">
                <button id="postCommentBtn">Post comment</button>
            </div>
        </div>
        
        <div class="user-spot-section">
            <strong>📍 Add a new safe spot</strong>
            <div class="user-spot-form">
                <input type="text" id="newSpotName" placeholder="Place name (e.g., 'Love's - Exit 123')">
                <input type="text" id="newSpotDesc" placeholder="Description (optional)">
                <button id="addSpotBtn">➕ Add my location</button>
            </div>
            <small style="color: #666;">⚠️ Click the map where you want to add the spot first</small>
        </div>
    </div>
    <button id="exportCsvBtn" class="export-btn">📎 Download CSV snapshot</button>
    <div class="warning">
        ⚠️ Not legal advice. Always check local signs. Votes & spots save for everyone instantly.
    </div>
    <footer>❤️ Anonymous • No login needed • Data shared with community • Be safe out there</footer>
</div>

<script>
    // ============================================================
    // FIREBASE CONFIGURATION - REAL DATABASE (I'll give you these)
    // For now, it uses localStorage as fallback
    // ============================================================
    
    // REAL FIREBASE KEYS - Replace these with the ones I'll send you
    const FIREBASE_CONFIG = {
        apiKey: "YOUR_API_KEY",
        authDomain: "YOUR_PROJECT.firebaseapp.com",
        databaseURL: "https://YOUR_PROJECT.firebaseio.com",
        projectId: "YOUR_PROJECT",
        storageBucket: "YOUR_PROJECT.appspot.com",
        messagingSenderId: "YOUR_SENDER_ID",
        appId: "YOUR_APP_ID"
    };
    
    // Set this to true AFTER I give you real keys
    const USE_FIREBASE = false;
    
    // Initialize Firebase if using
    let database = null;
    if (USE_FIREBASE && FIREBASE_CONFIG.apiKey !== "YOUR_API_KEY") {
        firebase.initializeApp(FIREBASE_CONFIG);
        database = firebase.database();
        console.log("🔥 Firebase connected");
    } else {
        console.log("💾 Using localStorage fallback (votes only save on this device)");
    }
    
    // ============================================================
    // OKLAHOMA LOCATIONS (16 spots with Academy, Bass Pro, Cabela's)
    // ============================================================
    const defaultLocations = [
        { id: "walmart_okc1", name: "Walmart Supercenter - OKC", lat: 35.4676, lng: -97.5164, category: "Walmart", isUserSpot: false },
        { id: "walmart_tulsa", name: "Walmart - Tulsa", lat: 36.1539, lng: -95.9928, category: "Walmart", isUserSpot: false },
        { id: "loves_iona", name: "Love's Travel Stop - I-44", lat: 35.6131, lng: -97.4078, category: "Truck Stop", isUserSpot: false },
        { id: "pilot_henryetta", name: "Pilot Flying J - Henryetta", lat: 35.4398, lng: -95.9815, category: "Truck Stop", isUserSpot: false },
        { id: "cracker_barrel_norman", name: "Cracker Barrel - Norman", lat: 35.2226, lng: -97.4395, category: "Restaurant", isUserSpot: false },
        { id: "planet_fitness_moore", name: "Planet Fitness - Moore", lat: 35.3392, lng: -97.4867, category: "24h Gym", isUserSpot: false },
        { id: "mercy_hospital_okc", name: "Mercy Hospital OKC", lat: 35.5387, lng: -97.5783, category: "Hospital", isUserSpot: false },
        { id: "ok_rest_area_i35", name: "I-35 Rest Area - Pauls Valley", lat: 34.7418, lng: -97.2249, category: "Rest Area", isUserSpot: false },
        { id: "academy_sports_tulsa", name: "Academy Sports + Outdoors - Tulsa", lat: 36.1121, lng: -95.9368, category: "Sporting Goods", isUserSpot: false },
        { id: "bass_pro_okc", name: "Bass Pro Shops - OKC", lat: 35.4987, lng: -97.5466, category: "Outdoor", isUserSpot: false },
        { id: "cabelas_tulsa", name: "Cabela's - Tulsa (Broken Arrow)", lat: 36.0461, lng: -95.8327, category: "Outdoor", isUserSpot: false },
        { id: "walmart_lawton", name: "Walmart - Lawton", lat: 34.6036, lng: -98.416, category: "Walmart", isUserSpot: false },
        { id: "loves_ardmore", name: "Love's - Ardmore I-35", lat: 34.1743, lng: -97.1437, category: "Truck Stop", isUserSpot: false },
        { id: "planet_fitness_edmond", name: "Planet Fitness - Edmond", lat: 35.6528, lng: -97.4781, category: "24h Gym", isUserSpot: false },
        { id: "bass_pro_tulsa", name: "Bass Pro Shops - Tulsa (BA)", lat: 36.0649, lng: -95.7928, category: "Outdoor", isUserSpot: false },
        { id: "academy_sports_okc", name: "Academy Sports - OKC North", lat: 35.579, lng: -97.552, category: "Sporting Goods", isUserSpot: false }
    ];
    
    // ============================================================
    // LOCAL STORAGE FALLBACK (works immediately, no Firebase needed)
    // ============================================================
    let localData = {
        votes: {},
        comments: {},
        userSpots: {}
    };
    
    function loadLocalData() {
        const stored = localStorage.getItem("ok_parking_data");
        if (stored) {
            try {
                localData = JSON.parse(stored);
            } catch(e) { console.error("Failed to parse stored data"); }
        }
        if (!localData.votes) localData.votes = {};
        if (!localData.comments) localData.comments = {};
        if (!localData.userSpots) localData.userSpots = {};
    }
    
    function saveLocalData() {
        localStorage.setItem("ok_parking_data", JSON.stringify(localData));
    }
    
    // ============================================================
    // USERNAME SYSTEM (adjective + noun, no repeats)
    // ============================================================
    let currentUsername = "";
    let usedNameSet = new Set();
    
    const adjectives = ["Quiet", "Sleepy", "Nocturnal", "Stealth", "Gray", "Gentle", "Wandering", "Calm", "Deep", "Lone", "Silver", "Cozy", "Friendly", "Brave", "Clever", "Mellow", "Soft", "Rustic", "Night", "Hidden", "Rolling", "Free", "Brave", "Calm", "Swift"];
    const nouns = ["Owl", "Caravan", "Camper", "Tumbleweed", "PrairieDog", "Roadrunner", "Coyote", "Moon", "Shadow", "Wanderer", "Hatchback", "Prius", "Van", "Ranger", "Nomad", "Drifter", "Puma", "Bison", "Starling", "Willow", "Traveler", "Sleeper", "Nomad"];
    
    function generateRandomUsername() {
        let availableAdj = adjectives.filter(a => !usedNameSet.has(a));
        let availableNoun = nouns.filter(n => !usedNameSet.has(n));
        if (availableAdj.length === 0) availableAdj = [...adjectives];
        if (availableNoun.length === 0) availableNoun = [...nouns];
        const adj = availableAdj[Math.floor(Math.random() * availableAdj.length)];
        const noun = availableNoun[Math.floor(Math.random() * availableNoun.length)];
        const full = `${adj}${noun}`;
        usedNameSet.add(adj);
        usedNameSet.add(noun);
        return full;
    }
    
    function loadUsername() {
        let stored = localStorage.getItem("ok_safe_username");
        let storedUsed = localStorage.getItem("ok_safe_used_tokens");
        if (storedUsed) {
            try { usedNameSet = new Set(JSON.parse(storedUsed)); } catch(e) {}
        }
        if (stored && stored.trim() !== "") {
            currentUsername = stored;
        } else {
            currentUsername = generateRandomUsername();
            localStorage.setItem("ok_safe_username", currentUsername);
            localStorage.setItem("ok_safe_used_tokens", JSON.stringify([...usedNameSet]));
        }
        document.getElementById("usernameSpan").innerText = currentUsername;
    }
    
    function changeUsername() {
        let newName = prompt("Enter a new username (or leave blank for random)", "");
        if (newName && newName.trim() !== "") {
            currentUsername = newName.trim().substring(0, 25);
        } else {
            currentUsername = generateRandomUsername();
            localStorage.setItem("ok_safe_used_tokens", JSON.stringify([...usedNameSet]));
        }
        localStorage.setItem("ok_safe_username", currentUsername);
        document.getElementById("usernameSpan").innerText = currentUsername;
    }
    
    // ============================================================
    // MAP AND MARKERS
    // ============================================================
    let map, markers = [];
    let allLocations = [];
    let currentPlaceId = null;
    let pendingSpotLatLng = null;
    
    // Color logic: yellow default, green if any yes, red if any no
    function getColorFromVotes(yes, no) {
        if (yes > 0 && no === 0) return "#2e7d32"; // green - safe
        if (no > 0 && yes === 0) return "#c62828"; // red - risky
        if (yes > 0 && no > 0) return "#f9a825"; // amber - mixed
        return "#ffd966"; // yellow - no votes
    }
    
    function createMarkerIcon(color, isUserSpot = false) {
        if (isUserSpot) {
            return L.divIcon({
                className: 'user-spot-icon',
                html: `<img src="BlueTack.png" style="width: 32px; height: 32px; filter: drop-shadow(2px 2px 2px rgba(0,0,0,0.3));" onerror="this.src='https://cdn-icons-png.flaticon.com/512/189/189121.png'">`,
                iconSize: [32, 32],
                popupAnchor: [0, -16]
            });
        }
        return L.divIcon({
            className: 'parking-spot-icon',
            html: `<div style="background-color: ${color}; width: 22px; height: 22px; border-radius: 50%; border: 3px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3); transition: 0.1s;"></div>`,
            iconSize: [22, 22],
            popupAnchor: [0, -11]
        });
    }
    
    function rebuildMarkers() {
        // Clear existing markers
        markers.forEach(m => map.removeLayer(m));
        markers = [];
        
        // Merge user spots with defaults
        const spots = [...defaultLocations];
        for (let [id, spot] of Object.entries(localData.userSpots)) {
            spots.push({
                id: id,
                name: spot.name,
                lat: spot.lat,
                lng: spot.lng,
                category: spot.description || "User submitted",
                isUserSpot: true,
                submittedBy: spot.submittedBy,
                submittedAt: spot.submittedAt
            });
        }
        allLocations = spots;
        
        for (let loc of spots) {
            const votes = localData.votes[loc.id] || { yes: 0, no: 0 };
            const color = getColorFromVotes(votes.yes, votes.no);
            const icon = createMarkerIcon(color, loc.isUserSpot);
            
            const marker = L.marker([loc.lat, loc.lng], { icon: icon }).addTo(map);
            marker.id = loc.id;
            marker.locData = loc;
            
            let popupContent = `<b>${escapeHtml(loc.name)}</b><br>${escapeHtml(loc.category)}`;
            if (loc.isUserSpot && loc.submittedBy) {
                popupContent += `<br><small>📍 Added by ${escapeHtml(loc.submittedBy)} on ${loc.submittedAt}</small>`;
            }
            popupContent += `<br>✅ ${votes.yes} 👍 | 👎 ${votes.no}<br><button onclick="window.selectLocation('${loc.id}')">View & Vote</button>`;
            
            marker.bindPopup(popupContent);
            marker.on('click', () => {
                selectLocation(loc.id);
            });
            markers.push(marker);
        }
    }
    
    function selectLocation(placeId) {
        currentPlaceId = placeId;
        const loc = allLocations.find(l => l.id === placeId);
        if (loc) document.getElementById("selectedPlaceName").innerHTML = loc.name;
        
        const votes = localData.votes[placeId] || { yes: 0, no: 0 };
        const total = votes.yes + votes.no;
        let statusText = "";
        if (votes.yes > 0 && votes.no === 0) statusText = "🟢 GREEN - reportedly safe";
        else if (votes.no > 0 && votes.yes === 0) statusText = "🔴 RED - reported risky";
        else if (votes.yes > 0 && votes.no > 0) statusText = "🟡 Mixed reports - caution advised";
        else statusText = "⚪ No votes yet (unknown)";
        
        document.getElementById("voteScore").innerHTML = `👍 ${votes.yes} | 👎 ${votes.no} — ${statusText}`;
        
        // Render comments
        const comments = localData.comments[placeId] || [];
        const commentDiv = document.getElementById("commentList");
        if (comments.length === 0) {
            commentDiv.innerHTML = "<em>No comments yet. Be the first.</em>";
        } else {
            commentDiv.innerHTML = comments.slice().reverse().map(c => {
                const isOld = (new Date() - new Date(c.rawTimestamp)) > (90 * 24 * 60 * 60 * 1000);
                return `
                    <div class="comment-item">
                        <div class="comment-header">
                            <span class="comment-name">${escapeHtml(c.username)}</span>
                            <span class="comment-time">📅 ${c.timestamp}</span>
                        </div>
                        <div class="comment-text">💬 ${escapeHtml(c.text)}</div>
                        ${isOld ? '<div class="old-comment-warning">⚠️ This comment is over 3 months old — conditions may have changed.</div>' : ''}
                    </div>
                `;
            }).join("");
        }
    }
    
    function updateMarkerColor(placeId) {
        const marker = markers.find(m => m.id === placeId);
        if (!marker || marker.locData?.isUserSpot) return;
        const votes = localData.votes[placeId] || { yes: 0, no: 0 };
        const color = getColorFromVotes(votes.yes, votes.no);
        marker.setIcon(createMarkerIcon(color, false));
    }
    
    // ============================================================
    // VOTING, COMMENTS, USER SPOTS
    // ============================================================
    function vote(type) {
        if (!currentPlaceId) { alert("Click a marker on the map first"); return; }
        if (!localData.votes[currentPlaceId]) localData.votes[currentPlaceId] = { yes: 0, no: 0 };
        if (type === 'yes') localData.votes[currentPlaceId].yes++;
        else localData.votes[currentPlaceId].no++;
        saveLocalData();
        updateMarkerColor(currentPlaceId);
        selectLocation(currentPlaceId);
    }
    
    function addComment() {
        const text = document.getElementById("commentInput").value;
        if (!currentPlaceId) { alert("Select a location first"); return; }
        if (!text.trim()) return;
        
        const now = new Date();
        const formattedDate = now.toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        
        const newComment = {
            username: currentUsername,
            text: text.substring(0, 200),
            timestamp: formattedDate,
            rawTimestamp: now.toISOString()
        };
        
        if (!localData.comments[currentPlaceId]) localData.comments[currentPlaceId] = [];
        localData.comments[currentPlaceId].push(newComment);
        saveLocalData();
        selectLocation(currentPlaceId);
        document.getElementById("commentInput").value = "";
    }
    
    function addUserSpot() {
        if (!pendingSpotLatLng) {
            alert("First click on the map where you want to add the spot");
            return;
        }
        const name = document.getElementById("newSpotName").value.trim();
        if (!name) {
            alert("Please enter a place name");
            return;
        }
        const desc = document.getElementById("newSpotDesc").value.trim();
        const now = new Date();
        const formattedDate = now.toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        
        const spotId = "user_" + Date.now() + "_" + Math.random().toString(36).substr(2, 6);
        localData.userSpots[spotId] = {
            name: name,
            description: desc,
            lat: pendingSpotLatLng.lat,
            lng: pendingSpotLatLng.lng,
            submittedBy: currentUsername,
            submittedAt: formattedDate,
            rawTimestamp: now.toISOString()
        };
        saveLocalData();
        
        alert("Spot added! It will appear as a blue tack on the map.");
        document.getElementById("newSpotName").value = "";
        document.getElementById("newSpotDesc").value = "";
        pendingSpotLatLng = null;
        rebuildMarkers();
    }
    
    function exportCSV() {
        let csvRows = [["Place ID", "Name", "Category", "Yes Votes", "No Votes", "Total Votes", "Is User Spot", "Submitted By", "Submitted Date"]];
        
        for (let loc of allLocations) {
            const votes = localData.votes[loc.id] || { yes: 0, no: 0 };
            csvRows.push([
                loc.id, 
                `"${loc.name}"`, 
                `"${loc.category}"`, 
                votes.yes, 
                votes.no, 
                votes.yes + votes.no,
                loc.isUserSpot ? "Yes" : "No",
                `"${loc.submittedBy || ""}"`,
                `"${loc.submittedAt || ""}"`
            ]);
        }
        
        const csvContent = csvRows.map(row => row.join(",")).join("\n");
        const blob = new Blob([csvContent], { type: "text/csv" });
        const link = document.createElement("a");
        const url = URL.createObjectURL(blob);
        link.href = url;
        link.download = `ok_parking_${new Date().toISOString().slice(0,10)}.csv`;
        link.click();
        URL.revokeObjectURL(url);
    }
    
    function escapeHtml(str) {
        if (!str) return "";
        return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));
    }
    
    // ============================================================
    // INITIALIZE MAP
    // ============================================================
    function initMap() {
        map = L.map('map').setView([35.5, -97.5], 7);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; CartoDB',
            subdomains: 'abcd',
            maxZoom: 19
        }).addTo(map);
        
        // Click to set pending spot location
        map.on('click', (e) => {
            pendingSpotLatLng = e.latlng;
            const popup = L.popup()
                .setLatLng(e.latlng)
                .setContent(`📍 Location set! Now enter a name and click "Add my location"`)
                .openOn(map);
            setTimeout(() => map.closePopup(popup), 3000);
        });
        
        loadLocalData();
        loadUsername();
        rebuildMarkers();
        if (allLocations.length > 0) selectLocation(allLocations[0].id);
    }
    
    // Make selectLocation global for popup buttons
    window.selectLocation = selectLocation;
    
    // Event listeners
    document.getElementById("thumbUpBtn").addEventListener("click", () => vote('yes'));
    document.getElementById("thumbDownBtn").addEventListener("click", () => vote('no'));
    document.getElementById("postCommentBtn").addEventListener("click", addComment);
    document.getElementById("changeNameBtn").addEventListener("click", changeUsername);
    document.getElementById("addSpotBtn").addEventListener("click", addUserSpot);
    document.getElementById("exportCsvBtn").addEventListener("click", exportCSV);
    
    // Start the map
    initMap();
</script>
</body>
